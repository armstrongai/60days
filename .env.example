# Netlify (and local copy if you use Netlify CLI). Never commit filled-in values.

# Vite inject → browser (public anon key and payment link URL only)
SUPABASE_URL=
SUPABASE_ANON_KEY=
STRIPE_TRIAL_PAYMENT_LINK=

# Reference IDs from Stripe Dashboard or `node scripts/stripe-setup.mjs` (functions/webhooks only)
STRIPE_BETA_PRICE_ID=
STRIPE_STANDARD_PRICE_ID=
STRIPE_TRIAL_PRICE_ID=

# Netlify functions — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# create-portal-session return URL after customer leaves the Stripe billing portal
STRIPE_PORTAL_RETURN_URL=https://45days.thelearningindex.com/app/

# Optional: STRIPE_PORTAL_URL is not a fixed URL (sessions are created by the API).
# Configure the Customer portal in Stripe Dashboard → Billing → Customer portal.
